{
  "name": "kinlink",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api",
    "dev:web": "npm --workspace @kinlink/web run dev",
    "dev:api": "npm --workspace @kinlink/api run dev",
    "build": "npm-run-all build:web build:api",
    "build:web": "npm --workspace @kinlink/web run build",
    "build:api": "npm --workspace @kinlink/api run build",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "lint": "echo 'lint placeholder'",
    "seed": "tsx scripts/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "prisma": "^6.1.0"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "zod": "^3.24.1"
  }
}
